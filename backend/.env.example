# ---------------------------------------------------------------------------
# IMC&IPM 商业决策智能体 - 环境变量示例
# 复制为 .env 后按需修改。所有外部服务都有本地回退，缺省也能离线启动。
# ---------------------------------------------------------------------------

APP_NAME="IMC&IPM 商业决策智能体"
ENVIRONMENT=local

# 数据库：生产用 PostgreSQL；缺省回退到本地 SQLite，便于离线开发
# DATABASE_URL=postgresql+psycopg://imcipm:imcipm@localhost:5432/imcipm
DATABASE_URL=sqlite:///./data/imc_ipm.db

# Qdrant 向量库；不可达时自动回退到内存实现
QDRANT_URL=http://localhost:6333
METHODOLOGY_CORE_COLLECTION=methodology_core_chunks
EXPANSION_COLLECTION=expansion_chunks

# DeepSeek (OpenAI 兼容)。缺省 key 时 LLM 走本地确定性回退，保证可跑通闭环
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 腾讯云短信验证码登录
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
TENCENTSMS_SDK_APP_ID=
TENCENTSMS_SIGN_NAME=
TENCENTSMS_TEMPLATE_ID=
TENCENTSMS_TEMPLATE_PARAM_COUNT=1
SMS_CODE_TTL_SECONDS=300
SMS_CODE_SEND_INTERVAL_SECONDS=60
SMS_CODE_MAX_ATTEMPTS=5
AUTH_SESSION_TTL_DAYS=30

# Embedding 可插拔：local(默认，中文字符 n-gram 哈希) | openai(OpenAI 兼容端点)
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=256
# 当 EMBEDDING_PROVIDER=openai 时使用以下配置
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=bge-m3

# 文件存储目录
STORAGE_DIR=./data/uploads
