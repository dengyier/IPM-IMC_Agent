# ============================================================================
# 天机AI 商业决策智能体 部署配置模板
# 复制为 .env 后填写。docker compose 会自动读取本文件。
#   cp .env.example .env
# ============================================================================

ENVIRONMENT=production

# --- 公网访问根地址（前端构建期注入，务必是浏览器能访问到的根地址，不要带 /api）---
#   走 nginx（推荐）：填域名或服务器公网IP，例如  http://123.45.67.89  或  https://imc.example.com
#   直连后端端口调试：填  http://服务器IP:18005  （并在 docker-compose.yml 放开 api/frontend 端口）
PUBLIC_BASE_URL=http://localhost:18005

# --- PostgreSQL（生产环境务必改成强密码）---
POSTGRES_DB=imc_ipm
POSTGRES_USER=imc
POSTGRES_PASSWORD=change-me-strong-password

# --- DeepSeek 大模型（留空则后端走本地确定性回退，可先跑通流程再补）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# --- Embedding（local 为内置实现，无需外部服务）---
#   EMBEDDING_DIM 必须与已建向量集合维度一致，迁移老数据时不要修改（当前为 256）
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=256

# --- 腾讯云短信验证码登录（留空则无法发送验证码，但不影响其它功能）---
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
TENCENTSMS_SDK_APP_ID=
TENCENTSMS_SIGN_NAME=
TENCENTSMS_TEMPLATE_ID=
TENCENTSMS_TEMPLATE_PARAM_COUNT=1
SMS_CODE_TTL_SECONDS=300
SMS_CODE_SEND_INTERVAL_SECONDS=60
SMS_CODE_MAX_ATTEMPTS=5
AUTH_SESSION_TTL_DAYS=30

# 说明：DATABASE_URL / QDRANT_URL / STORAGE_DIR 由 docker-compose.yml 自动指向容器内服务，
#       无需在此配置（如非 Docker 部署可手动设置）。
