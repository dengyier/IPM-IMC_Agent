APP_NAME=IMC&IPM Decision Agent
ENVIRONMENT=local

DATABASE_URL=postgresql+psycopg://imc:imc_password@postgres:5432/imc_ipm
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=imc_ipm_chunks

STORAGE_DIR=/data/uploads

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

NEXT_PUBLIC_API_BASE=http://127.0.0.1:18005

TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
TENCENTSMS_SDK_APP_ID=
TENCENTSMS_SIGN_NAME=
TENCENTSMS_TEMPLATE_ID=
TENCENTSMS_TEMPLATE_PARAM_COUNT=1
SMS_CODE_TTL_SECONDS=300
SMS_CODE_SEND_INTERVAL_SECONDS=60
SMS_CODE_MAX_ATTEMPTS=5
AUTH_SESSION_TTL_DAYS=30

POSTGRES_DB=imc_ipm
POSTGRES_USER=imc
POSTGRES_PASSWORD=imc_password
MINIO_ROOT_USER=imc
MINIO_ROOT_PASSWORD=imc_password
